# Local development. The .data/ dir is gitignored; the file is created on first migration.
DATABASE_URL=file:./.data/zhua.db
# DATABASE_AUTH_TOKEN is only required for libsql:// (Turso) connections.

# Edge Middleware basic-auth gate. Required for any non-localhost deployment.
# If either var is missing in production, the gate fails closed and serves 401.
# Localhost (NODE_ENV=development) bypasses the gate.
BASIC_AUTH_USER=ceo
BASIC_AUTH_PASSWORD=change-me
